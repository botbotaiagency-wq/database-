{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.js": {
      "includeFiles": "server/data.json"
    }
  },
  "rewrites": [
    { "source": "/api/contacts/:id", "destination": "/api/contacts/[id]" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
